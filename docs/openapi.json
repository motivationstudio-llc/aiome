  "components": {
    "schemas": {
      "AgentChatRequest": {
        "type": "object",
        "required": [
          "prompt",
          "history"
        ],
        "properties": {
          "channel_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            }
          },
          "prompt": {
            "type": "string"
          }
        }
      },
      "AutoToggle": {
        "type": "object",
        "required": [
          "enabled"
        ],
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        }
      },
      "ChatMessage": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "content": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "GraphData": {
        "type": "object",
        "required": [
          "nodes",
          "edges"
        ],
        "properties": {
          "edges": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GraphEdge"
            }
          },
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GraphNode"
            }
          }
        }
      },
      "GraphEdge": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        }
      },
      "GraphNode": {
        "type": "object",
        "required": [
          "id",
          "label",
          "group"
        ],
        "properties": {
          "group": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        }
      },
      "ImmuneRule": {
        "type": "object",
        "description": "自己防衛のための免疫ルール",
        "required": [
          "id",
          "pattern",
          "severity",
          "action",
          "created_at"
        ],
        "properties": {
          "action": {
            "type": "string",
            "description": "適用するアクション (Block, Warn, Quarantine, Revoke)"
          },
          "created_at": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "lamport_clock": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "node_id": {
            "type": "string"
          },
          "pattern": {
            "type": "string",
            "description": "検知パターンの記述 (自然言語または正規表現)"
          },
          "severity": {
            "type": "integer",
            "format": "int32",
            "description": "ルールの重要度 (1-100)",
            "minimum": 0
          },
          "signature": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ImportRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "KarmaFeedbackRequest": {
        "type": "object",
