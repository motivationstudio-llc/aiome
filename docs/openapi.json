{
  "openapi": "3.1.0",
  "info": {
    "title": "Aiome Management Console API",
    "description": "Core API for the Autonomous AI Operating System",
    "license": {
      "name": "ELv2",
      "identifier": "ELv2"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "crate::routes::general"
        ],
        "operationId": "get_health_status",
        "responses": {
          "200": {
            "description": "Get current system and agent health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResourceStatus"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/api/skills": {
      "get": {
        "tags": [
          "crate::routes::skill"
        ],
        "operationId": "list_skills",
        "responses": {
          "200": {
            "description": "List all active skills in the Swarm",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SkillSummary"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/api/skills/import": {
      "post": {
        "tags": [
          "crate::routes::skill"
        ],
        "operationId": "import_skill",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Skill imported successfully"
          },
          "400": {
            "description": "Invalid URL or fetch failed"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Security Block (SSRF)"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/api/v1/logs": {
      "get": {
        "tags": [
          "crate::routes::general"
        ],
        "operationId": "get_logs",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of logs to return",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fetch application logs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LogEntryResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/settings": {
      "get": {
        "tags": [
          "crate::routes::settings"
        ],
        "operationId": "get_settings",
        "responses": {
          "200": {
            "description": "List all settings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SystemSetting"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      },
      "put": {
        "tags": [
          "crate::routes::settings"
        ],
        "operationId": "update_setting",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSettingsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Setting updated successfully"
          },
          "400": {
            "description": "Invalid request or unauthorized key"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    },
    "/api/v1/settings/test": {
      "post": {
        "tags": [
          "crate::routes::settings"
        ],
        "operationId": "test_connection",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TestConnectionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Connection test completed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TestConnectionResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "ImportRequest": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "LogEntryResponse": {
        "type": "object",
        "required": [
          "id",
          "level",
          "target",
          "message"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "level": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "timestamp": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "McpSpawnRequest": {
        "type": "object",
        "required": [
          "id",
          "command",
          "args"
        ],
        "properties": {
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "command": {
            "type": "string"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "ResourceStatus": {
        "type": "object",
        "description": "リソースの使用状況",
        "required": [
          "memory_usage_mb",
          "total_memory_mb",
          "cpu_usage_percent",
          "disk_free_gb",
          "total_disk_gb",
          "level",
          "exp",
          "resonance",
          "creativity",
          "fatigue"
        ],
        "properties": {
          "cpu_usage_percent": {
            "type": "number",
            "format": "float"
          },
          "creativity": {
            "type": "integer",
            "format": "int32"
          },
          "disk_free_gb": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "exp": {
            "type": "integer",
            "format": "int32"
          },
          "fatigue": {
            "type": "integer",
            "format": "int32"
          },
          "level": {
            "type": "integer",
            "format": "int32"
          },
          "memory_usage_mb": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "open_files": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "resonance": {
            "type": "integer",
            "format": "int32"
          },
          "total_disk_gb": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "total_memory_mb": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "vram_usage_mb": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "SkillSummary": {
        "type": "object",
        "required": [
          "name",
          "description",
          "source",
          "status",
          "layer",
          "tools"
        ],
        "properties": {
          "description": {
            "type": "string"
          },
          "layer": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tools": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SystemSetting": {
        "type": "object",
        "description": "System Setting entry for Management Console",
        "required": [
          "key",
          "value",
          "category",
          "is_secret",
          "updated_at"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "is_secret": {
            "type": "boolean"
          },
          "key": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "TestConnectionRequest": {
        "type": "object",
        "required": [
          "service",
          "url"
        ],
        "properties": {
          "model": {
            "type": [
              "string",
              "null"
            ]
          },
          "service": {
            "type": "string"
          },
          "token": {
            "type": [
              "string",
              "null"
            ]
          },
          "url": {
            "type": "string"
          }
        }
      },
      "TestConnectionResponse": {
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          }
        }
      },
      "UpdateSettingsRequest": {
        "type": "object",
        "required": [
          "key",
          "value",
          "category"
        ],
        "properties": {
          "category": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "api_key": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API_SERVER_SECRET"
      }
    }
  }
}