# --- Aiome Core Configuration (OSS) ---

## 1. Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_LOG_CHANNEL_ID=your_log_channel_id
DISCORD_COMMAND_CHANNEL_ID=your_command_channel_id
DISCORD_CHAT_CHANNEL_ID=your_chat_channel_id

## 2. AI Engine Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

## 3. Remote/External Service Configuration (Optional)
# URL for the external generation engine (if any)
EXTERNAL_SERVICE_URL=ws://127.0.0.1:8188/ws

## 4. Federated Knowledge & Security
# Unique name for this node
NODE_ID=node_01
# Password shared between nodes for federation sync
FEDERATION_SECRET=your_secure_federation_password
# Hub URL or Peer URLs (comma-separated)
FEDERATION_PEERS=http://hub.aiome.dev,http://localhost:5000

## 5. System Features
ADVANCED_EXPERIENCE_MODE=false
LOG_LEVEL=info
JSON_LOGS=true

# =========================================================================
# 🔴 [SECURE PROXY CONFIGURATION - ABYSS VAULT] 🔴
# =========================================================================
# Use the Key-Proxy (Abyss Vault) to handle sensitive API keys.
# Run: GEMINI_API_KEY=xxx cargo run --bin key-proxy

# URL pointing to your key-proxy instance
KEY_PROXY_URL=http://127.0.0.1:9999
KEY_PROXY_PORT=9999

# The following keys are NOT used by the main daemon directly.
# They should be passed to the 'key-proxy' process environment.
# GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key

# -- Advanced Search & Research (WASM Skills) --
# BRAVE_SEARCH_API_KEY=your_brave_key
