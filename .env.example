# --- Aiome Core Configuration (OSS) ---

## 1. Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_LOG_CHANNEL_ID=your_log_channel_id
DISCORD_COMMAND_CHANNEL_ID=your_command_channel_id
DISCORD_CHAT_CHANNEL_ID=your_chat_channel_id

## 2. AI Engine Configuration (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
# Default Gemini engine for Command Mode (Required if using Gemini logic)
GEMINI_API_KEY=AIzaSy...your_gemini_api_key

## 3. Media Generation (ComfyUI)
# Use ws://localhost:8188/ws for real-time API connection
COMFYUI_API_URL=ws://127.0.0.1:8188/ws
# Root directory of your local ComfyUI installation
COMFYUI_BASE_DIR=/Users/your_user/Desktop/ComfyUI
# (Optional fallback)
COMFYUI_URL=http://127.0.0.1:8188

## 4. Federation & Self-Healing
# Unique name for this node (must be unique in the network)
NODE_ID=node_01
# Password shared between nodes for federation sync
FEDERATION_SECRET=your_secure_federation_password
# Hub URL or Peer URLs (comma-separated)
FEDERATION_PEERS=http://hub.aiome.dev,http://localhost:5000

## 5. System Features
UNLEASHED_MODE=false
LOG_LEVEL=info
JSON_LOGS=true

# =========================================================================
# 🔴 [OPTIONAL - PRO / ENTERPRISE MODULES ONLY] 🔴
# =========================================================================
# The following variables are only used by proprietary components or 
# specific advanced modules in Aiome Enterprise editions.

