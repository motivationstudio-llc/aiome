# --- Aiome Core Configuration (OSS) ---

## 1. Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_LOG_CHANNEL_ID=your_log_channel_id
DISCORD_COMMAND_CHANNEL_ID=your_command_channel_id
DISCORD_CHAT_CHANNEL_ID=your_chat_channel_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

## 2. AI Engine Configuration (Ollama / Cloud)
# Primary LLM provider: ollama, gemini, openai, anthropic, lmstudio
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LM_STUDIO_HOST=http://localhost:1234

# API Keys (Required if using Cloud providers directly)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_claude_api_key

## 3. Background AI Engine (Autonomous Tasks)
BG_LLM_PROVIDER=ollama
BG_LLM_MODEL=qwen2.5:7b

## 4. Embedding Configuration (Semantic Search / RAG)
# Primary: ruri-v3 local (free, Japanese-optimized), gemini, openai
EMBEDDING_PROVIDER=ruri
RURI_EMBED_URL=http://localhost:8100

## 5. Federated Knowledge & Security
# Unique name for this node (Used for Biome identity)
NODE_ID=node_01
# Password shared between nodes for federation sync
FEDERATION_SECRET=your_secure_federation_password
# Hub URLs
SAMSARA_HUB_REST=http://127.0.0.1:3016
SAMSARA_HUB_WS=ws://127.0.0.1:3016/api/v1/federation/ws
API_WS_URL=ws://localhost:3015/api/v1/watchtower/ws

## 6. System & Security Features
ADVANCED_EXPERIENCE_MODE=false
LOG_LEVEL=info
JSON_LOGS=true
PORT=3015
ENFORCE_GUARDRAIL=true
# Global secret to access Aiome API (Required)
API_SERVER_SECRET=a_very_long_random_string
AIOME_DB_PATH=sqlite://workspace/aiome.db

## 7. MCP (Model Context Protocol)
# Directory for MCP server configuration discovery
MCP_CONFIG_PATH=~/.aiome/mcp_servers.json

## 8. External Integrations
# Used for DreamState / Creative Research
SEARCH_API_KEY=your_google_custom_search_or_tavily_key
BRAVE_SEARCH_API_KEY=your_brave_key

# =========================================================================
# 🔴 [SECURE PROXY CONFIGURATION - ABYSS VAULT] 🔴
# =========================================================================
# Use the Key-Proxy (Abyss Vault) to handle sensitive API keys centrally.

# Auth token to access the Abyss Vault (VAULT_SECRET in proxy environment)
# Must match whatever is set in key-proxy
VAULT_SECRET=your_secure_vault_access_secret

# URL pointing to your key-proxy instance
KEY_PROXY_URL=http://127.0.0.1:9999
KEY_PROXY_PORT=9999

# The following keys are NOT used by the main daemon directly if KEY_PROXY is active.
# They should be passed to the 'key-proxy' process environment.
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBED_MODEL=text-embedding-004
